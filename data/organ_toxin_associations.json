{
  "_note": "Evidence-tiered organ/meridian -> characteristic environmental-toxin associations for the clinical glossary. Curated from peer-reviewed toxicology (research pass 2026-07-14). Tiers: strong (agency review/meta-analysis) / moderate / weak-contested. Meridians inherit their organ's toxins via the 'entry_keys' map. This is a reference layer, not a diagnosis; tiers and route-vs-accumulation caveats are stated per row.",
  "associations": {
    "stomach": [
      {"toxin": "Heavy metals (Cd, Pb, Hg, Cr, As)", "tier": "moderate", "note": "Mucosal-barrier disruption (Cd²⁺ displaces Ca²⁺ at E-cadherin junctions) and raised H. pylori susceptibility. A route-of-entry and acute target, not a storage organ.", "source": "Yuan 2016, BioMed Res Int", "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC5075591/"}
    ],
    "gi": [
      {"toxin": "Heavy metals (gut barrier, microbiota)", "tier": "moderate", "note": "Oxidative stress, altered microbiota and 'leaky gut'.", "source": "Front. Nutrition 2024", "url": "https://www.frontiersin.org/journals/nutrition/articles/10.3389/fnut.2024.1448388/full"},
      {"toxin": "Trichothecene mycotoxins (T-2)", "tier": "moderate", "note": "Protein-synthesis inhibitor; injures GI tract and hematopoietic progenitors (largely animal data).", "source": "Front. review 2017", "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC5464924/"}
    ],
    "pancreas": [
      {"toxin": "Organochlorines / POPs & PCBs (β-cell, type-2 diabetes)", "tier": "strong", "note": "Meta-analysis: p,p′-DDE OR 1.33, total PCBs OR 2.14 for T2D; POPs measured in human pancreatic tissue.", "source": "Tang 2014, PLoS One (meta-analysis)", "url": "https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0085556"},
      {"toxin": "Organophosphate pesticides (acute pancreatitis)", "tier": "moderate", "note": "Pancreatitis in ~6–29% of OP poisonings; ACh hyperstimulation of the acinus + ampullary obstruction. Case series.", "source": "Yoshida 2015, J Intensive Care", "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC4422543/"},
      {"toxin": "BPA (insulin signaling / metabolic)", "tier": "moderate", "note": "Estradiol mimic disrupting islet insulin signaling; human endpoints contested.", "source": "Rev. Endocr. Metab. Disord.", "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9072519/"}
    ],
    "liver": [
      {"toxin": "Aflatoxin B1 (HCC)", "tier": "strong", "note": "IARC Group 1; TP53 R249S adduct; multiplicative synergy with HBV (RR ~1 → ~60–70).", "source": "Kew 2003, Liver Int", "url": "https://onlinelibrary.wiley.com/doi/10.1111/j.1478-3231.2003.00869.x"},
      {"toxin": "Carbon tetrachloride (zone-3 necrosis → cirrhosis)", "tier": "strong", "note": "CYP2E1 → trichloromethyl radical → lipid peroxidation.", "source": "ATSDR CSEM", "url": "https://archive.cdc.gov/www_atsdr_cdc_gov/csem/carbon-tetrachloride/toxicological_effects.html"},
      {"toxin": "PFAS (PFOA/PFOS) — steatosis / MASLD", "tier": "strong", "note": "PPARα activation + UPR; liver + cholesterol effects hold up best in the C8 data.", "source": "C8 Science Panel", "url": "https://www.sciencedirect.com/science/article/pii/S0160412020320808"},
      {"toxin": "Organochlorines (NAFLD)", "tier": "moderate", "note": "Hepatic mitochondrial dysfunction.", "source": "PMC9270488", "url": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9270488/"}
    ],
    "lung": [
      {"toxin": "Paraquat (primary target)", "tier": "strong", "note": "Active uptake via polyamine transporters → alveolar redox-cycling ROS → fibrosis.", "source": "Crit. Rev. Toxicol. 2021", "url": "https://www.tandfonline.com/doi/full/10.1080/10408444.2020.1864721"},
      {"toxin": "Nickel, chromium, arsenic, cadmium (respiratory injury / cancer)", "tier": "strong", "note": "Ni & Cr(VI) IARC Group 1 for lung; As & Cd also respiratory.", "source": "IARC v49 / ATSDR", "url": "https://www.inchem.org/documents/iarc/vol49/nickel.html"}
    ],
    "brain": [
      {"toxin": "Lead", "tier": "strong", "note": "Critical CNS target; developmental neurotoxicity at low levels.", "source": "ATSDR ToxProfile 13", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp13.pdf"},
      {"toxin": "Mercury (vapor / methylmercury)", "tier": "strong", "note": "Crosses BBB and placenta; the neuro form (elemental salts spare the CNS, hit kidney).", "source": "ATSDR ToxProfile 46", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp46.pdf"},
      {"toxin": "Aluminum", "tier": "moderate", "note": "Dialysis encephalopathy is established; the Alzheimer's link is contested.", "source": "ATSDR ToxProfile 22", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp22.pdf"},
      {"toxin": "Solvents (toluene) & organophosphates", "tier": "strong", "note": "White-matter degeneration (toluene); AChE inhibition + excitotoxicity (OPs).", "source": "ATSDR tp56 / Toxics 2023", "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC10611379/"}
    ],
    "bone": [
      {"toxin": "Lead (reservoir, ~94% body burden)", "tier": "strong", "note": "Ca-mimic in hydroxyapatite; remobilizes in pregnancy/menopause.", "source": "ATSDR ToxProfile 13", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp13.pdf"},
      {"toxin": "Radium-226/228 (osteosarcoma)", "tier": "strong", "note": "Bone-seeking Ca-mimic; alpha-emission irradiates osteogenic tissue ('radium girls').", "source": "ATSDR ToxProfile 144", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp144.pdf"},
      {"toxin": "Cadmium (itai-itai osteomalacia)", "tier": "strong", "note": "Secondary to renal phosphate/calcium wasting.", "source": "ATSDR ToxProfile 5", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp5-c2.pdf"}
    ],
    "kidney": [
      {"toxin": "Cadmium (primary accumulation organ)", "tier": "strong", "note": "Metallothionein-bound, endocytosed via megalin:cubilin → proximal-tubule injury; ↑urinary β2M.", "source": "ATSDR ToxProfile 5", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp5-c2.pdf"},
      {"toxin": "Mercury (inorganic / elemental salts)", "tier": "strong", "note": "Proximal-tubule injury and autoimmune nephritis (this Hg form spares the CNS).", "source": "ATSDR ToxProfile 46", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp46.pdf"},
      {"toxin": "Trichloroethylene (renal cancer)", "tier": "strong", "note": "IARC Group 1 for kidney cancer; tubular damage.", "source": "NTP 15th Report on Carcinogens", "url": "https://www.ncbi.nlm.nih.gov/books/NBK590886/"},
      {"toxin": "Ochratoxin A (nephropathy)", "tier": "moderate", "note": "Balkan endemic nephropathy; IARC 2B. Rat lesions differ from human pathology.", "source": "PubMed 16332622", "url": "https://pubmed.ncbi.nlm.nih.gov/16332622/"}
    ],
    "blood_marrow": [
      {"toxin": "Benzene (AML, aplastic anemia)", "tier": "strong", "note": "Hydroquinone metabolites target hematopoietic stem cells; IARC Group 1.", "source": "IARC Monograph 120", "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC7812544/"},
      {"toxin": "Whole-body ionizing radiation (leukemia)", "tier": "strong", "note": "Marrow is highly radiosensitive; leukemia is the first and highest-RR radiation malignancy.", "source": "PMC3875218", "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC3875218/"},
      {"toxin": "Lead (heme synthesis → anemia)", "tier": "strong", "note": "Inhibits δ-ALAD and ferrochelatase.", "source": "ATSDR ToxProfile 13", "url": "https://www.atsdr.cdc.gov/toxprofiles/tp13.pdf"}
    ],
    "testes": [
      {"toxin": "Phthalates (DEHP) — 'phthalate syndrome'", "tier": "strong", "note": "Anti-androgen: suppresses fetal Leydig steroidogenesis (↓anogenital distance, hypospadias, cryptorchidism). Strong in animals, moderate in humans.", "source": "PubMed 16690193", "url": "https://pubmed.ncbi.nlm.nih.gov/16690193/"},
      {"toxin": "BPA (reproductive/endocrine)", "tier": "moderate", "note": "Estrogenic disruption of steroidogenesis.", "source": "NTP CLARITY-BPA context", "url": "https://pubmed.ncbi.nlm.nih.gov/23796010/"}
    ]
  },
